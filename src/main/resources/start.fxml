<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.image.Image?>
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="edu.farmingdale.demo1.StartController"
           fx:id="rootPane">


    <!-- Background image (stretches fullscreen) -->
    <ImageView fx:id="bgImage" pickOnBounds="true" preserveRatio="false">
        <image>
            <Image url="@images/start_screen.png"/>
        </image>
    </ImageView>

    <!-- Centered VBox for logo and buttons -->
    <VBox spacing="40" alignment="CENTER">

        <!-- PlanetSim Logo -->
        <Label text="PlanetSim" style="-fx-font-size: 48px; -fx-font-weight: bold; -fx-text-fill: orange;"/>

        <!-- Menu buttons (fixed size, centered) -->
        <VBox spacing="20" alignment="CENTER">
            <Button text="Start Game" prefWidth="300" onAction="#handleStartGame"/>
            <Button text="New Game" prefWidth="300" onAction="#handleNewGame"/>
            <Button text="Settings" prefWidth="300" onAction="#handleSettings"/>
            <Button text="Exit" prefWidth="300" onAction="#handleExit"/>
        </VBox>

    </VBox>

</StackPane>
