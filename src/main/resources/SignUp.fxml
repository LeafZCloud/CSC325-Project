<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<StackPane fx:id="SignUpPane"
           xmlns="http://javafx.com/javafx/17.0.12"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="edu.farmingdale.demo1.SignUpController">

    <!-- Background -->
    <ImageView fx:id="bgImage"
               pickOnBounds="true"
               preserveRatio="false"
               smooth="true">
        <image>
            <Image url="@images/Background.png" />
        </image>
    </ImageView>

    <!-- Centered login UI -->
    <VBox alignment="CENTER" spacing="22" translateY="-20">

        <!-- Username holder + real text field -->
        <StackPane>
            <ImageView fx:id="EmailHolder"
                       fitWidth="360"
                       preserveRatio="true">
                <image>
                    <Image url="@images/UsernameHolder.png" />
                </image>
            </ImageView>

            <TextField fx:id="emailField"
                       promptText="Email:"
                       maxWidth="280"
                       style="-fx-background-color: transparent; -fx-text-fill: white; -fx-prompt-text-fill: rgba(255,255,255,0.75); -fx-font-size: 24px;" />
        </StackPane>

        <!-- Password holder + real password field -->
        <StackPane>
            <ImageView fx:id="PasswordHolder"
                       fitWidth="360"
                       preserveRatio="true">
                <image>
                    <Image url="@images/PasswordHolder.png" />
                </image>
            </ImageView>

            <PasswordField fx:id="passwordField"
                           promptText="Password:"
                           maxWidth="280"
                           style="-fx-background-color: transparent; -fx-text-fill: white; -fx-prompt-text-fill: rgba(255,255,255,0.75); -fx-font-size: 24px;" />
        </StackPane>

        <!-- Signup button image + invisible real button -->
        <StackPane>
            <ImageView fx:id="SignupButtonImage"
                       fitWidth="280"
                       preserveRatio="true">
                <image>
                    <Image url="@images/SignUpButton.png" />
                </image>
            </ImageView>

            <Button text=""
                    prefWidth="280"
                    prefHeight="80"
                    onAction="#handleSignUp"
                    style="-fx-background-color: transparent; -fx-border-color: transparent;" />
        </StackPane>

        <!-- Status message -->
        <Label fx:id="statusLabel"
               textFill="RED"
               style="-fx-font-size: 16px; -fx-font-weight: bold;" />

    </VBox>

</StackPane>