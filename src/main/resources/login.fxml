<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.image.Image?>
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="edu.farmingdale.demo1.LoginController"
           fx:id="rootPane">


    <!-- Stretchy background -->
    <ImageView fx:id="bgImage" pickOnBounds="true" preserveRatio="false">
        <image>
            <Image url="@images/start_screen.png"/>
        </image>
    </ImageView>

    <!-- Centered VBox (fixed size children) -->
    <VBox spacing="20" alignment="CENTER">

        <Label text="PlanetSim" style="-fx-font-size: 48px; -fx-font-weight: bold; -fx-text-fill: orange;"/>
        <TextField fx:id="usernameField" promptText="Username" prefWidth="300" maxWidth="300"/>
        <PasswordField fx:id="passwordField" promptText="Password" prefWidth="300" maxWidth="300"/>
        <Button text="Login" prefWidth="300"  maxWidth="300"  onAction="#handleLogin"/>
        <Button text="Create Account"  prefWidth="300"  maxWidth="300" onAction="#handleCreateAccount"/>
        <Label fx:id="statusLabel" textFill="RED"/>

    </VBox>

</StackPane>