<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<StackPane fx:id="rootPane" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="edu.farmingdale.demo1.LoginController">


    <!-- Stretchy background -->
    <ImageView fx:id="bgImage" pickOnBounds="true">

        <Image url="@images/Background.png"/>
    </ImageView>

    <!-- Planet Sim Logo -->
    <ImageView fx:id="planetSimLogo" fitWidth="1250.0" preserveRatio="true" translateY="-100">

        <Image url="@images/PlanetSimLogo.png"/>
    </ImageView>

    <!-- Centered VBox (fixed size children) -->
    <VBox alignment="CENTER" spacing="20">
        <TextField fx:id="usernameField" maxWidth="300" prefWidth="300" promptText="Username" />
        <PasswordField fx:id="passwordField" maxWidth="300" prefWidth="300" promptText="Password" />
        <Button maxWidth="300" onAction="#handleLogin" prefWidth="300" text="Login" />
        <Button maxWidth="300" onAction="#handleCreateAccount" prefWidth="300" text="Create Account" />
        <Label fx:id="statusLabel" textFill="RED" />

    </VBox>

</StackPane>
