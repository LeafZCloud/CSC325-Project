<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="edu.farmingdale.demo1.LoginController">
    <children>
        <Label layoutX="196.0" layoutY="55.0" text="PlanetSim">
            <font>
                <Font size="36" />
            </font>
        </Label>
        <TextField fx:id="usernameField" layoutX="200.0" layoutY="150.0" promptText="Username" />
        <PasswordField fx:id="passwordField" layoutX="200.0" layoutY="200.0" promptText="Password" />
        <Button layoutX="250.0" layoutY="260.0" onAction="#handleLogin" text="Login" />
        <Label fx:id="statusLabel" layoutX="200.0" layoutY="300.0" textFill="RED" />
    </children>
</AnchorPane>
