<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:id="rootPane"
           xmlns="http://javafx.com/javafx/17.0.12"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="edu.farmingdale.demo1.LoginController">

    <!-- Background -->
    <ImageView fx:id="bgImage"
               pickOnBounds="true"
               preserveRatio="false"
               smooth="true">
        <image>
            <Image url="@images/Background.png" />
        </image>
    </ImageView>

    <!-- Centered login UI -->
    <VBox alignment="CENTER" spacing="22" translateY="-20">

        <!-- Username holder + real text field -->
        <StackPane>
            <ImageView fx:id="EmailHolder"
                       fitWidth="360"
                       preserveRatio="true">
                <image>
                    <Image url="@images/UsernameHolder.png" />
                </image>
            </ImageView>

            <TextField fx:id="emailField"
                       promptText="Email:"
                       maxWidth="280"
                       style="-fx-background-color: transparent; -fx-text-fill: white; -fx-prompt-text-fill: rgba(255,255,255,0.75); -fx-font-size: 24px;" />
        </StackPane>

        <!-- Password holder + real password field -->
        <StackPane>
            <ImageView fx:id="PasswordHolder"
                       fitWidth="360"
                       preserveRatio="true">
                <image>
                    <Image url="@images/PasswordHolder.png" />
                </image>
            </ImageView>

            <PasswordField fx:id="passwordField"
                           promptText="Password:"
                           maxWidth="280"
                           style="-fx-background-color: transparent; -fx-text-fill: white; -fx-prompt-text-fill: rgba(255,255,255,0.75); -fx-font-size: 24px;" />
        </StackPane>

        <!-- Login button image + invisible real button -->
        <StackPane>
            <ImageView fx:id="loginButtonImage"
                       fitWidth="280"
                       preserveRatio="true">
                <image>
                    <Image url="@images/LoginButton.png" />
                </image>
            </ImageView>

            <Button text=""
                    prefWidth="280"
                    prefHeight="80"
                    onAction="#handleLogin"
                    style="-fx-background-color: transparent; -fx-border-color: transparent;" />
        </StackPane>

        <Button text="Temp Enter Game"
                onAction="#handleTempEnterGame"
                style="-fx-background-color: rgba(15,23,42,0.85); -fx-text-fill: white; -fx-font-size: 18px; -fx-background-radius: 10; -fx-padding: 10 22; -fx-cursor: hand;" />

        <!-- Status message -->
        <Label fx:id="statusLabel"
               textFill="RED"
               style="-fx-font-size: 16px; -fx-font-weight: bold;" />

    </VBox>

    <!-- Back button (Top-Left) -->
    <StackPane alignment="TOP_LEFT"
               pickOnBounds="false"
               translateX="15"
               translateY="15">

        <ImageView fx:id="backButtonImage"
                   fitWidth="96"
                   preserveRatio="true"
                   pickOnBounds="true">
            <image>
                <Image url="@images/BackButton.png" />
            </image>
        </ImageView>

        <Button text=""
                minWidth="96"
                prefWidth="96"
                maxWidth="96"
                minHeight="96"
                prefHeight="96"
                maxHeight="96"
                onAction="#handleBack"
                style="-fx-background-color: transparent; -fx-border-color: transparent;" />

    </StackPane>

</StackPane>
